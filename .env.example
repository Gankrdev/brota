# ---------- Database (Neon Postgres) ----------
# Get from https://console.neon.tech (use the pooled connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---------- NextAuth (Auth.js v5) ----------
# Generate with: openssl rand -base64 32  (or: npx auth secret)
AUTH_SECRET=""
# Only needed if NEXTAUTH_URL detection fails (e.g. behind a proxy)
# AUTH_URL="http://localhost:3000"

# ---------- Seed users (run once with: npm run db:seed) ----------
# Admin (you)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME=""
# Regular user (your wife)
SEED_USER_EMAIL=""
SEED_USER_PASSWORD=""
SEED_USER_NAME=""

# ---------- AI ----------
# Gemini 2.5 Flash — used for plant identification and species fact-sheet generation
GOOGLE_GENAI_API_KEY=""

# Claude Sonnet 4.6 — used for health diagnosis from plant photos
ANTHROPIC_API_KEY=""

# ---------- Vercel Blob (image storage) ----------
# Get from Vercel dashboard → Storage → Blob → connect store
BLOB_READ_WRITE_TOKEN=""

# ---------- Web Push notifications ----------
# Generate VAPID keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contacto.joshua.cid@gmail.com"
